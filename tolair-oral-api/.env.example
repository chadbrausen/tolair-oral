# Reveal Oral Health — Backend Environment Variables
# Copy to .env and fill in real values from Azure Key Vault (tolair-vault)

# Database — Azure Key Vault: DATABASE_URL_ORAL
DATABASE_URL="postgresql://USER:PASSWORD@tolair-db.postgres.database.azure.com:5432/tolair?schema=public"

# Anthropic Claude API — Azure Key Vault: ANTHROPIC_API_KEY_ORAL
ANTHROPIC_API_KEY=""

# HubSpot CRM — Azure Key Vault: HUBSPOT_API_KEY (shared)
HUBSPOT_API_KEY=""

# Email (SendGrid) — Azure Key Vault: SMTP_PASS_ORAL
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS=""
SMTP_FROM="noreply@tolair.org"

# Application
PORT=3004
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
